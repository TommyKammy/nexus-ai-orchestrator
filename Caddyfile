n8n-s-app01.tmcast.net {

    # Security headers for all responses
    header {
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        X-Content-Type-Options "nosniff"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        # Avoid conflicting X-Frame-Options values from upstream and proxy.
        X-Frame-Options "SAMEORIGIN"
    }

    # Internal-only service prefixes must never be edge-routable.
    @internal_only path /internal/* /executor/* /opa/* /postgres/* /redis/*
    respond @internal_only 404

    # Legacy Slack slash command paths - rewrite to n8n webhook
    @slack_legacy path /slack/command /slack-command
    handle @slack_legacy {
        rewrite * /webhook/slack-command
        reverse_proxy n8n:5678 {
            header_up -X-Internal-Auth
            header_up X-Internal-Auth {env.SLACK_INTERNAL_AUTH}
        }
    }

    # Handle Slack slash commands - bypass API key check
    handle /webhook/slack-command {
        reverse_proxy n8n:5678 {
            header_up -X-Internal-Auth
            header_up X-Internal-Auth {env.SLACK_INTERNAL_AUTH}
        }
    }

    # Block unauthorized webhook requests (API key protection for all other webhooks)
    @unauthorized {
        path /webhook/*
        not header X-API-Key {env.N8N_WEBHOOK_API_KEY}
    }

    respond @unauthorized 401 {
        body "Unauthorized: Invalid or missing API key"
    }

    # Lightweight policy registry UI
    handle /policy-ui* {
        reverse_proxy policy-bundle-server:8088
    }

    # Main reverse proxy with proper headers for n8n UI auth
    reverse_proxy n8n:5678 {
        header_up Host {host}
        header_up X-Real-IP {remote}
        header_up X-Forwarded-For {remote}
        header_up X-Forwarded-Proto {scheme}
        # Upstream may emit its own X-Frame-Options; keep only the proxy value.
        header_down -X-Frame-Options
    }
}
